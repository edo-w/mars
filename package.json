{
	"name": "mars",
	"module": "index.ts",
	"scripts": {
		"fmt": "biome format --write",
		"lint": "biome check --write",
		"check": "tsgo",
		"test": "vitest run",
		"cover": "vitest run --coverage",
		"coverv": "powershell -Command \"Start-Process dist/coverage/index.html\"",
		"mars": "bun src/cli/main.ts",
		"make:win": "bun build --target=bun-windows-x64 --compile --outfile dist/mars.exe src/cli/main.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@changesets/cli": "^2.30.0",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@openai/codex": "^0.115.0",
		"@types/bun": "latest",
		"@typescript/native-preview": "^7.0.0-dev.20260319.1",
		"@vitest/coverage-istanbul": "4.1.0",
		"vite": "^8.0.1",
		"vitest": "^4.1.0"
	},
	"private": true,
	"type": "module",
	"dependencies": {
		"@aws-sdk/client-kms": "^3.1016.0",
		"@aws-sdk/client-s3": "^3.1014.0",
		"@edo-w/tiny": "^0.2.0",
		"@logtape/file": "^2.0.5",
		"@logtape/logtape": "^2.0.4",
		"argon2": "^0.44.0",
		"commander": "^14.0.3",
		"enquirer": "^2.4.1",
		"yaml": "^2.8.2",
		"zod": "^4.3.6"
	}
}
